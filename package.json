{
  "name": "digitaljs-schematic-viewer",
  "displayName": "DigitalJS Schematic Viewer",
  "description": "Synthesises Verilog/SystemVerilog files via the DigitalJS server and renders the interactive circuit simulator directly inside VSCode.",
  "version": "1.0.7",
  "publisher": "VENOMNBB",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VENOMNBB/DigitalJS-Schematic-Viewer"
  },
  "bugs": {
    "url": "https://github.com/VENOMNBB/DigitalJS-Schematic-Viewer/issues"
  },
  "homepage": "https://github.com/VENOMNBB/DigitalJS-Schematic-Viewer#readme",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Visualization",
    "Education",
    "Other"
  ],
  "keywords": [
    "Verilog",
    "SystemVerilog",
    "DigitalJS",
    "Simulation",
    "HDL",
    "Yosys",
    "Schematic",
    "Circuit",
    "Viewer",
    "Waveform"
  ],
  "activationEvents": [
    "onCommand:digitaljsOnline.open",
    "onCommand:digitaljsOnline.synthesizeDefault",
    "onView:digitaljs-settings"
  ],
  "main": "./extension.js",
  "dependencies": {
    "@yowasp/yosys": "release",
    "yosys2digitaljs": "latest"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "digitaljs-explorer",
          "title": "DigitalJS",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "digitaljs-explorer": [
        {
          "type": "webview",
          "id": "digitaljs-settings",
          "name": "Parameters",
          "icon": "icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "digitaljsOnline.open",
        "title": "Open in DigitalJS",
        "category": "DigitalJS",
        "icon": "icon.png"
      },
      {
        "command": "digitaljsOnline.synthesizeDefault",
        "title": "Synthesize in DigitalJS (defaults)",
        "category": "DigitalJS",
        "icon": "icon.png"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "digitaljsOnline.synthesizeDefault",
          "when": "resourceExtname == .v || resourceExtname == .sv",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "digitaljsOnline.open",
          "when": "resourceExtname == .v || resourceExtname == .sv",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "digitaljsOnline.open",
          "when": "resourceExtname == .v || resourceExtname == .sv",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "digitaljsOnline.open",
          "when": "resourceExtname == .v || resourceExtname == .sv"
        }
      ]
    }
  }
}